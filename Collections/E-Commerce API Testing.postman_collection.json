        {
          "name": "Get Product By ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "const jsonData = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Product ID is 1\", function () {\r",
                  "    pm.expect(jsonData.id).to.eql(1);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Product Title Exists\", function () {\r",
                  "    pm.expect(jsonData.title).to.exist;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Product Price Exists\", function () {\r",
                  "    pm.expect(jsonData.price).to.exist;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Category Exists\", function () {\r",
                  "    pm.expect(jsonData.category).to.exist;\r",
                  "});"
